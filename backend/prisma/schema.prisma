generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Severity {
  low
  medium
  high
  critical
}

enum Status {
  open
  investigating
  resolved
}

model Incident {
  id          String   @id @default(uuid())
  title       String
  description String
  service     String
  severity    Severity
  status      Status   @default(open)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}